{
  "info": {
    "_postman_id": "twikoranire-api-collection",
    "name": "Twikoranire API",
    "description": "Verified. Safe. Local. — Complete API collection for Twikoranire backend. \n\nSetup:\n1. Set `baseUrl` variable to `http://localhost:5000/api`\n2. Register and verify OTP to get tokens\n3. Access token auto-saves to `accessToken` variable after login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId",       "value": "", "type": "string" },
    { "key": "activityId",   "value": "", "type": "string" },
    { "key": "eventId",      "value": "", "type": "string" },
    { "key": "chatId",       "value": "", "type": "string" },
    { "key": "reportId",     "value": "", "type": "string" },
    { "key": "paymentId",    "value": "", "type": "string" },
    { "key": "ticketCode",   "value": "", "type": "string" },
    { "key": "groupId",      "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register (Send OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"+250780123456\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  pm.collectionVariables.set('userId', res.userId);",
                  "  pm.test('Tokens received', () => pm.expect(res.accessToken).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"+250780123456\",\n  \"otp\": \"123456\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Verify ID (National ID)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/verify-id", "host": ["{{baseUrl}}"], "path": ["auth","verify-id"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "id_image", "type": "file", "src": "" },
                { "key": "selfie",   "type": "file", "src": "" },
                { "key": "id_type",  "value": "NATIONAL_ID", "type": "text" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Verify ID (Passport / Tourist)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/verify-id", "host": ["{{baseUrl}}"], "path": ["auth","verify-id"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "id_image", "type": "file", "src": "" },
                { "key": "selfie",   "type": "file", "src": "" },
                { "key": "id_type",  "value": "PASSPORT", "type": "text" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] },
            "body": { "mode": "raw", "raw": "" }
          },
          "response": []
        }
      ]
    },

