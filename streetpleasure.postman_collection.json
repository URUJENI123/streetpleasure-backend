            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/reports/mine", "host": ["{{baseUrl}}"], "path": ["reports","mine"] }
