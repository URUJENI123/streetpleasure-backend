            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.report) pm.collectionVariables.set('reportId', res.report.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/reports", "host": ["{{baseUrl}}"], "path": ["reports"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reported_user_id\": \"{{userId}}\",\n  \"entity_type\": \"event\",\n  \"entity_id\": \"{{eventId}}\",\n  \"reason\": \"scam\",\n  \"description\": \"This user collected entry fees but the event never happened.\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get My Reports",
